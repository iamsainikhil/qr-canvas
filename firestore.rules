rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownerConfigPath() {
      return /databases/$(database)/documents/app_config/private;
    }

    function ownerConfigExists() {
      return exists(ownerConfigPath());
    }

    function ownerUid() {
      return get(ownerConfigPath()).data.ownerUid;
    }

    function isOwner() {
      return isSignedIn() && ownerConfigExists() && request.auth.uid == ownerUid();
    }

    // One-time bootstrap doc to lock this project to a single owner uid.
    match /app_config/private {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && !ownerConfigExists()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isOwner()
        && request.resource.data.ownerUid == resource.data.ownerUid;
    }

    match /users/{uid} {
      allow read, write: if isOwner() && uid == request.auth.uid;

      match /qrs/{qrId} {
        allow read, create, update, delete: if isOwner() && uid == request.auth.uid;

        // Scan events are written by server-side Admin SDK only.
        match /scans/{scanId} {
          allow read: if isOwner() && uid == request.auth.uid;
          allow write: if false;
        }
      }
    }

    match /qr_routes/{shortCode} {
      allow read, create, update, delete: if isOwner();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
