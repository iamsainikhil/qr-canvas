# publishable key safe to use on client side for logo.dev integration
NEXT_PUBLIC_LOGO_DEV_PUBLISHABLE_KEY=<value>

# Private mode environment variables
NEXT_PUBLIC_PRIVATE_MODE=true
OWNER_EMAIL=your-email@example.com

# Firebase Client SDK environment variables
NEXT_PUBLIC_FIREBASE_API_KEY=<value>
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=<value>
NEXT_PUBLIC_FIREBASE_PROJECT_ID=<value>
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=<value>
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=<value>
NEXT_PUBLIC_FIREBASE_APP_ID=<value>
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX  # from Firebase project settings > Your apps > Measurement ID

# Firebase Admin SDK environment variables
FIREBASE_PROJECT_ID=<value>
FIREBASE_CLIENT_EMAIL=<value>
FIREBASE_PRIVATE_KEY=<value>
SCAN_IP_HASH_SALT=<strong-random-secret>
