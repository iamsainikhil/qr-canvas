# Environment variables for logo.dev integration
VITE_LOGO_DEV_PUBLISHABLE_KEY="<value>"

# Private mode environment variables
VITE_PRIVATE_MODE="true"
VITE_OWNER_EMAIL="your-email@example.com"

# Firebase Client SDK environment variables
VITE_FIREBASE_API_KEY="<value>"
VITE_FIREBASE_AUTH_DOMAIN="<value>"
VITE_FIREBASE_PROJECT_ID="<value>"
VITE_FIREBASE_STORAGE_BUCKET="<value>"
VITE_FIREBASE_MESSAGING_SENDER_ID="<value>"
VITE_FIREBASE_APP_ID="<value>"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"  # from Firebase project settings > Your apps > Measurement ID

# Firebase Admin SDK environment variables
FIREBASE_PROJECT_ID="<value>"
FIREBASE_CLIENT_EMAIL="<value>"
FIREBASE_PRIVATE_KEY="<value>"
SCAN_IP_HASH_SALT="<strong-random-secret>"
